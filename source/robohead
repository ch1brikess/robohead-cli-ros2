def check_ros():
    if not WS_ROOT.exists():
        print(f"ROS workspace не найден: {WS_ROOT}")
        sys.exit(1)

def run_cmd(cmd):
    try:
        subprocess.run(cmd, shell=True, check=True, cwd=str(Path.home()), executable='/bin/bash')
    except Exception as e:
        print(f"Ошибка: {e}")
        sys.exit(1)

def run_cmd_capture(cmd):
    try:
        result = subprocess.run(cmd, shell=True, capture_output=True, text=True, cwd=str(Path.home()), executable='/bin/bash')
        return result.stdout
    except:
        return None

def backup(filepath):
    if filepath.exists():
        backup_path = str(filepath) + ".bak"
        shutil.copy2(filepath, backup_path)
        print(f"Бэкап: {backup_path}")

def add_to_yaml_list(filepath, key, value):
    """Добавить элемент в список YAML, сохраняя форматирование"""
    if not filepath.exists():
        print(f"Файл не найден: {filepath}")
        return False
    
    backup(filepath)
    
    with open(filepath, 'r', encoding='utf-8') as f:
        lines = f.readlines()
    
    # Находим секцию с ключом
    in_section = False
    insert_index = None
    base_indent = 0
    
    for i, line in enumerate(lines):
        stripped = line.strip()
        
        # Нашли ключ списка (wake_phrases: или fast_commands: или commands:)
        if f'{key}:' in stripped and not in_section:
            in_section = True
            base_indent = len(line) - len(line.lstrip())
            insert_index = i + 1
            continue
        
        # Если в секции, ищем конец списка
        if in_section:
            current_indent = len(line) - len(line.lstrip())
            
            # Пустая строка или новый ключ с меньшим отступом - конец списка
            if stripped and not stripped.startswith('-') and current_indent <= base_indent:
                break
            
            # Нашли последний элемент списка
            if stripped.startswith('-'):
                insert_index = i + 1
    
    if insert_index is None:
        print(f"Секция '{key}' не найдена")
        return False
    
    # Добавляем новый элемент с правильным отступом и кавычками
    new_line = ' ' * (base_indent + 2) + f'- "{value}"\n'
    lines.insert(insert_index, new_line)
    
    with open(filepath, 'w', encoding='utf-8') as f:
        f.writelines(lines)
    
    print(f"Добавлено: {value}")
    return True

def remove_from_yaml_list(filepath, key, value):
    """Удалить элемент из списка YAML, сохраняя форматирование"""
    if not filepath.exists():
        print(f"Файл не найден: {filepath}")
        return False
    
    backup(filepath)
    
    with open(filepath, 'r', encoding='utf-8') as f:
        lines = f.readlines()
    
    in_section = False
    removed = False
    
    for i, line in enumerate(lines):
        stripped = line.strip()
        
        # Нашли ключ списка
        if f'{key}:' in stripped and not in_section:
            in_section = True
            continue
        
        # Если в секции, ищем элемент для удаления
        if in_section:
            current_indent = len(line) - len(line.lstrip())
            
            # Конец списка
            if stripped and not stripped.startswith('-') and current_indent == 0:
                break
            
            # Проверяем элемент списка
            if stripped.startswith('-'):
                # Удаляем кавычки и пробелы для сравнения
                item = stripped[1:].strip().strip('"').strip("'")
                if item.lower() == value.lower():
                    lines.pop(i)
                    removed = True
                    print(f"Удалено: {value}")
                    break
    
    if not removed:
        print(f"Не найдено: {value}")
    
    with open(filepath, 'w', encoding='utf-8') as f:
        f.writelines(lines)
    
    return removed

def get_yaml_list(filepath, key):
    """Получить список из YAML файла"""
    if not filepath.exists():
        return []
    
    with open(filepath, 'r', encoding='utf-8') as f:
        lines = f.readlines()
    
    items = []
    in_section = False
    
    for line in lines:
        stripped = line.strip()
        
        if f'{key}:' in stripped and not in_section:
            in_section = True
            continue
        
        if in_section:
            current_indent = len(line) - len(line.lstrip())
            
            if stripped and not stripped.startswith('-') and current_indent == 0:
                break
            
            if stripped.startswith('-'):
                item = stripped[1:].strip().strip('"').strip("'")
                items.append(item)
    
    return items

def set_yaml_list(filepath, key, value):
    """Установить единственный элемент в списке YAML"""
    if not filepath.exists():
        print(f"Файл не найден: {filepath}")
        return False
    
    backup(filepath)
    
    with open(filepath, 'r', encoding='utf-8') as f:
        lines = f.readlines()
    
    in_section = False
    start_index = None
    end_index = None
    base_indent = 0
    
    for i, line in enumerate(lines):
        stripped = line.strip()
        
        if f'{key}:' in stripped and not in_section:
            in_section = True
            base_indent = len(line) - len(line.lstrip())
            start_index = i + 1
            continue
        
        if in_section:
            current_indent = len(line) - len(line.lstrip())
            
            if stripped and not stripped.startswith('-') and current_indent <= base_indent:
                end_index = i
                break
    
    if start_index is None:
        print(f"Секция '{key}' не найдена")
        return False
    
    # Удаляем старые элементы списка
    if end_index is None:
        end_index = len(lines)
    
    new_line = ' ' * (base_indent + 2) + f'- "{value}"\n'
    lines[start_index:end_index] = [new_line]
    
    with open(filepath, 'w', encoding='utf-8') as f:
        f.writelines(lines)
    
    print(f"Установлено: {value}")
    return True

def check_pishrink():
    if not os.path.exists(PISHRINK_PATH):
        print("PiShrink не найден. Установка...")
        run_cmd(f"wget https://raw.githubusercontent.com/Drewsif/PiShrink/master/pishrink.sh -O {PISHRINK_PATH}")
        run_cmd(f"chmod +x {PISHRINK_PATH}")

